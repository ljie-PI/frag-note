# Runtime
HOST=0.0.0.0
PORT=3000

# Supabase runtime
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_RAW_BUCKET=captures-raw
SUPABASE_STORAGE_DERIVED_BUCKET=captures-derived

# Drizzle / SQL workflows
# Optional. apps/api/drizzle.config.ts falls back to
# postgresql://postgres:postgres@127.0.0.1:5432/frag_note when omitted.
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:5432/frag_note

# LLM provider configuration (global defaults)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

# Per-function overrides (optional; falls back to global LLM_API_KEY / LLM_BASE_URL)
SUMMARY_MODEL=gpt-4.1-mini
# SUMMARY_API_KEY=
# SUMMARY_BASE_URL=

EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=

TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# TRANSCRIPTION_API_KEY=
# TRANSCRIPTION_BASE_URL=

OCR_MODEL=gpt-4.1-mini
# OCR_API_KEY=
# OCR_BASE_URL=

# Desktop frontend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_BASE_URL=http://127.0.0.1:3000
