# Runtime
HOST=0.0.0.0
PORT=3000

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_RAW_BUCKET=captures-raw
SUPABASE_STORAGE_DERIVED_BUCKET=captures-derived

# Drizzle / migrations
# Optional. If omitted, apps/api/drizzle.config.ts falls back to
# postgresql://postgres:postgres@127.0.0.1:5432/sui_note
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:5432/sui_note

# AI provider
# Optional in the current main branch. If missing, the app falls back to
# heuristic/local processing where supported.
OPENAI_API_KEY=

# Desktop frontend
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# If you later deploy Supabase Edge Functions, keep these server-side values
# available in Supabase secrets as well. Example:
# supabase secrets set \
#   SUPABASE_URL="https://your-project-ref.supabase.co" \
#   SUPABASE_ANON_KEY="your-supabase-anon-key" \
#   SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key" \
#   SUPABASE_STORAGE_RAW_BUCKET="captures-raw" \
#   SUPABASE_STORAGE_DERIVED_BUCKET="captures-derived" \
#   OPENAI_API_KEY="your-openai-api-key"
