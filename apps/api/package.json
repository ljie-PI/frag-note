{
  "name": "@frag-note/api",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build ./src/server.ts ./src/worker.ts --outdir ./dist --target bun",
    "db:generate": "bunx drizzle-kit generate --config=drizzle.config.ts",
    "start": "bun run dist/server.js",
    "start:worker": "bun run dist/worker.js",
    "test:health": "bun test ../../tests/api/routes/health.test.ts",
    "test:shell": "bun test ../../tests/api/routes/health.test.ts ../../tests/api/server.test.ts ../../tests/api/worker.test.ts",
    "test": "bun test ../../tests/api",
    "test:env": "bun test ../../tests/api/lib/env.test.ts",
    "lint": "bun -e \"process.exit(0)\""
  },
  "dependencies": {
    "@frag-note/contracts": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "@types/node": "^24.6.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
