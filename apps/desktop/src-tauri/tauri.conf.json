{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Frag Note Desktop",
  "version": "0.1.0",
  "identifier": "com.fragnote.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Frag Note Desktop",
        "width": 1280,
        "height": 900,
        "decorations": false,
        "transparent": true,
        "shadow": false
      },
      {
        "label": "quick-capture",
        "title": "快速记录",
        "url": "/quick-capture.html",
        "width": 600,
        "height": 240,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
