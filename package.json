{
  "name": "frag-note",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --env-file=.env run scripts/dev.ts",
    "dev:reset": "bun --env-file=.env run scripts/dev.ts --reset",
    "build": "bun --env-file=.env run --workspaces build",
    "test": "bun --env-file=.env test ./tests --ignore=\"tests/e2e/**\"",
    "test:e2e": "bun --env-file=.env test tests/e2e/*.e2e.test.ts tests/e2e/helpers/ tests/e2e/setup/ --timeout 30000",
    "test:e2e:full": "bun --env-file=.env test tests/e2e/full/ --timeout 120000",
    "test:e2e:native": "bun --env-file=.env test tests/e2e/native/ --timeout 60000",
    "lint": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/bun": "^1.3.2",
    "selenium-webdriver": "^4.43.0"
  }
}
