{
  "name": "frag-note",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun --env-file=.env run --workspaces build",
    "test": "bun --env-file=.env test ./tests --ignore='tests/e2e/**'",
    "test:e2e": "bun test tests/e2e/ --timeout 30000",
    "lint": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/bun": "^1.3.2"
  }
}
